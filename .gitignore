node_modules/
dist/
docs/.vitepress/cache/
docs/.vitepress/dist/
bk/

# .companies/ は業務データだがGit管理対象（PRフローで管理）
# .companies/ は .gitignore に含めない

# .companies/.active はローカル設定（各ユーザーが独立して組織切替するため）
.companies/.active

# インタラクションログ（Hooks自動生成、Git管理外）
.companies/*/.interaction-log/

# セッション統計JSON（Hooks自動生成、Git管理外）
.companies/*/.session-summaries/

# エージェントメモリ（ローカル学習データ・Git管理外）
.claude/agent-memory/

# 会話ログ（ローカルのみ・プライバシー保護）
.companies/*/.conversation-log/

# Case Bank（ローカル学習データ）
.companies/*/.case-bank/

# Quality Gate ログ
.companies/*/.quality-gate-log/

# ロックファイル
.claude/scheduled_tasks.lock
