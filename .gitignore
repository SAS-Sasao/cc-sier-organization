# .companies/ は業務データだがGit管理対象（PRフローで管理）
# .companies/ は .gitignore に含めない

# .companies/.active はローカル設定（各ユーザーが独立して組織切替するため）
.companies/.active

# インタラクションログ（Hooks自動生成、Git管理外）
.companies/*/.interaction-log/

# セッション統計JSON — データドリブン意思決定アプリの素材として Git 管理対象化（2026-06-14）
# .companies/*/.session-summaries/

# エージェントメモリ（ローカル学習データ・Git管理外）
.claude/agent-memory/

# 会話ログ — 同上、Git 管理対象化（2026-06-14）。機微情報は [PHONE] 等マスキング前提
# .companies/*/.conversation-log/

# Case Bank（学習データ）— データドリブン意思決定アプリの素材として Git 管理対象化（2026-06-14）
# .companies/*/.case-bank/

# Quality Gate ログ — 同上、Git 管理対象化（2026-06-14）
# .companies/*/.quality-gate-log/

# ロックファイル
.claude/scheduled_tasks.lock

# MCP Server生成の一時ファイル（docs/diagrams/ にコピー済み）
generated-diagrams/
