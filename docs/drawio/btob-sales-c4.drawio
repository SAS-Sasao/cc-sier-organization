<!-- Notes -->
<mxCell id="note-ddd" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;DDD設計方針:&lt;/b&gt;&lt;br&gt;&#8226; 各BCは独立したドメインモデルを保持&lt;br&gt;&#8226; BC間通信はドメインイベント(SQS)＋Internal API&lt;br&gt;&#8226; Schema-per-Module でDB分離（将来のMS化に対応）&lt;br&gt;&#8226; 共通基盤(Shared Kernel)は最小限に抑制&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#FFC107;fontSize=10;size=14;align=left;spacingLeft=10;" vertex="1" parent="sys-boundary">
  <mxGeometry x="30" y="890" width="545" height="80" as="geometry"/>
</mxCell>
<mxCell id="note-aws" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;AWS インフラ構成:&lt;/b&gt;&lt;br&gt;&#8226; ECS Fargate (コンテナ実行)&lt;br&gt;&#8226; API Gateway + ALB (ルーティング)&lt;br&gt;&#8226; Cognito (認証) / CloudWatch + X-Ray (監視)&lt;br&gt;&#8226; SQS (非同期メッセージング)&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#FFC107;fontSize=10;size=14;align=left;spacingLeft=10;" vertex="1" parent="sys-boundary">
